// K-Lipa data model. Money is stored as BigInt in minor units
// (for RWF, which has no minor unit, store whole francs).
// Balances are NOT stored — they are computed (see prisma/rls.sql, customer_balance view).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Organisation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  category  String?
  currency  String   @default("RWF") @db.Char(3)
  logoUrl   String?  @map("logo_url")
  plan      String   @default("starter") // starter | growth | business
  // Where this business gets paid by ITS customers (shown on the invoice).
  momoCode    String? @map("momo_code")
  bankAccount String? @map("bank_account")
  // Platform subscription: null/past => still on the free tier and subject to
  // the free-invoice limit; a future date => paid until then. Renewal lands on
  // the same hour the subscription started (anniversary billing).
  subscribedUntil DateTime? @map("subscribed_until")
  // Renews each month unless the owner turns it off. Until a payment provider
  // can charge automatically, "renewal" = a payment-request email on the
  // anniversary; access pauses if it goes unpaid.
  autoRenew           Boolean   @default(true) @map("auto_renew")
  lastRenewalNoticeAt DateTime? @map("last_renewal_notice_at")
  createdAt DateTime @default(now()) @map("created_at")

  memberships Membership[]
  customers   Customer[]
  invoices    Invoice[]
  expenses    Expense[]
  invitations Invitation[]
  assistantMessages AssistantMessage[]

  @@map("organisation")
}

model UserProfile {
  // id equals the Supabase auth.users.id (the JWT `sub`).
  id        String   @id @db.Uuid
  fullName  String   @map("full_name")
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  memberships Membership[]

  @@map("user_profile")
}

// Records each acceptance of the Terms: who, when, which version, which language.
// This is what makes consent defensible to regulators and lenders later.
model ConsentRecord {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  termsVersion String   @map("terms_version")
  language     String // en | rw | fr | sw
  acceptedAt   DateTime @default(now()) @map("accepted_at")

  @@index([userId])
  @@map("consent_record")
}

model Membership {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String       @default("owner") // owner | admin | member
  createdAt      DateTime     @default(now()) @map("created_at")
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
  @@map("membership")
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  name           String
  email          String?
  phone          String?
  tin            String?
  createdAt      DateTime     @default(now()) @map("created_at")
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]

  @@index([organisationId])
  @@map("customer")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  organisationId String        @map("organisation_id") @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  number         String
  amountTotal    BigInt        @map("amount_total")
  currency       String        @db.Char(3)
  dueDate        DateTime      @map("due_date") @db.Date
  status         String        @default("draft") // draft|sent|due_soon|overdue|paid
  docType        String        @default("invoice") @map("doc_type") // invoice | quotation
  taxRate        Int           @default(0) @map("tax_rate") // basis points (100 = 1%)
  discount       BigInt        @default(0) // minor units, applied before tax
  description    String?
  publicToken    String?       @unique @map("public_token")
  pdfUrl         String?       @map("pdf_url")
  sentAt         DateTime?     @map("sent_at")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  organisation Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        InvoiceItem[]
  reminders    Reminder[]
  payments     Payment[]

  @@unique([organisationId, number])
  @@index([organisationId, status])
  @@index([organisationId, dueDate])
  @@map("invoice")
}

model InvoiceItem {
  id          String @id @default(uuid()) @db.Uuid
  invoiceId   String @map("invoice_id") @db.Uuid
  description String
  unitAmount  BigInt @map("unit_amount")
  quantity    Int    @default(1)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_item")
}

model Reminder {
  id           String    @id @default(uuid()) @db.Uuid
  invoiceId    String    @map("invoice_id") @db.Uuid
  stage        String // before_due | on_due | overdue_7 | overdue_14
  channel      String    @default("email")
  status       String    @default("scheduled") // scheduled|sent|skipped|failed
  scheduledFor DateTime  @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@map("reminder")
}

model Payment {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  amount    BigInt
  method    String   @default("manual") // manual | mobile_money | card
  // Gateway transaction id (e.g. Flutterwave), null for manual payments.
  // Unique so a retried webhook can't record the same payment twice.
  providerRef String? @unique @map("provider_ref")
  paidAt    DateTime @default(now()) @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payment")
}

// Staff invitations. An owner/admin invites an email; when that person signs in
// they can accept and get a membership in the organisation.
model Invitation {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  email          String
  role           String       @default("member") // owner | admin | member
  status         String       @default("pending") // pending | accepted | revoked
  createdAt      DateTime     @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("invitation")
}

// First-party usage events (screen views, key actions). Powers the admin
// analytics. No third-party SDK; only what the app itself reports.
model AppEvent {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  organisationId String?  @map("organisation_id") @db.Uuid
  event          String
  path           String?
  device         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("app_event")
}

// Klipwa AI chat memory: what each user asked and what the assistant said,
// so conversations continue across sessions and follow-up questions work.
model AssistantMessage {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String // user | assistant
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([organisationId, userId, createdAt(sort: Desc)])
  @@map("assistant_message")
}

// Business expenses — what the owner spends, for a real profit & loss.
model Expense {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  incurredAt     DateTime     @map("incurred_at") @db.Date
  category       String
  amount         BigInt
  note           String?
  receiptUrl     String?      @map("receipt_url")
  createdAt      DateTime     @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([organisationId, incurredAt])
  @@map("expense")
}
