    "@prisma/client": "^5.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
