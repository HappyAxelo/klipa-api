# ============ K-Lipa API environment ============
# Copy to .env and fill in. On Railway, set these as service Variables instead.

# ---- Database (Supabase Postgres) ----
# Supabase Dashboard > Project Settings > Database > Connection string.
# App uses the pooled connection (port 6543). Migrations use the direct one (5432).
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---- Supabase Auth ----
# Project Settings > API > JWT Secret. Verifies the tokens clients send.
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ---- App ----
PORT=4000
PUBLIC_APP_URL="https://k-lipa.rw"        # used to build the public invoice link
CURRENT_TERMS_VERSION="2026-05-01"        # bump when you change the Terms text

# ---- Email ----
# Leave as console in dev: emails are logged, not sent, so no credentials needed.
EMAIL_PROVIDER="console"                  # console | resend
RESEND_API_KEY=""
EMAIL_FROM="K-Lipa <invoices@k-lipa.rw>"
